        {
            "id": "mcp_0fa0abbd2685ef0c0069e9deaa46a0819a98b070f94ec13e55",
            "arguments": "{\"query\":\"SELECT \\n    MAX(f.DigitalBankingLoginTransaction_Timestamp) AS latest_login_date,\\n    DATEADD(MONTH, -3, MAX(f.DigitalBankingLoginTransaction_Timestamp)) AS window_start_date,\\n    COUNT(DISTINCT CASE \\n        WHEN u.DigitalBankingUser_Current_Status = 'Active' \\n         AND u.dss_current_flag = 'Y'\\n        THEN f.dim_DigitalBankingUser_key \\n    END) AS active_users_logged_in_last_3_months,\\n    COUNT(*) AS total_login_rows_in_window\\nFROM fact.DigitalBankingLoginTransaction f\\nJOIN dim.DigitalBankingUser u\\n    ON f.dim_DigitalBankingUser_key = u.dim_DigitalBankingUser_key\\nWHERE f.DigitalBankingLoginTransaction_Timestamp > DATEADD(MONTH, -3, (\\n    SELECT MAX(DigitalBankingLoginTransaction_Timestamp)\\n    FROM fact.DigitalBankingLoginTransaction\\n))\\n  AND f.DigitalBankingLoginTransaction_Timestamp <= (\\n    SELECT MAX(DigitalBankingLoginTransaction_Timestamp)\\n    FROM fact.DigitalBankingLoginTransaction\\n);\"}",
