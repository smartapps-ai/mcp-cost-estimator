            "arguments": "{\"query\":\"SELECT COUNT(DISTINCT f.dim_DigitalBankingUser_key) AS active_users_logged_in_last_3_months,\\n       MIN(f.DigitalBankingLoginTransaction_Timestamp) AS window_start_sample,\\n       MAX(f.DigitalBankingLoginTransaction_Timestamp) AS window_end_sample\\nFROM fact.DigitalBankingLoginTransaction f\\nJOIN dim.DigitalBankingUser u\\n  ON f.dim_DigitalBankingUser_key = u.dim_DigitalBankingUser_key\\nWHERE u.DigitalBankingUser_Current_Status = 'Active'\\n  AND u.dss_current_flag = 'Y'\\n  AND f.DigitalBankingLoginTransaction_Timestamp > DATEADD(month, -3, (SELECT MAX(DigitalBankingLoginTransaction_Timestamp) FROM fact.DigitalBankingLoginTransaction))\\n  AND f.DigitalBankingLoginTransaction_Timestamp <= (SELECT MAX(DigitalBankingLoginTransaction_Timestamp) FROM fact.DigitalBankingLoginTransaction);\"}",
